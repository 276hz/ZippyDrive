# Google API Key (API key, KHÔNG phải OAuth) - lấy free tại Google Cloud Console.
# Xem hướng dẫn chi tiết trong README.md
GOOGLE_API_KEY=

# --- Các biến dưới đây ĐỀU LÀ TUỲ CHỌN, không set thì dùng mặc định ---

# Giới hạn tổng dung lượng cho phép tải trong 1 lần (tính bằng byte).
# MẶC ĐỊNH (để trống) = KHÔNG GIỚI HẠN, folder bao nhiêu GB cũng tải được vì
# kiến trúc streaming không giữ file trong RAM. Chỉ set nếu bạn muốn tự giới
# hạn lại (ví dụ để tránh 1 lượt tải cực lớn chiếm slot quá lâu). Ví dụ 5GB:
MAX_TOTAL_DOWNLOAD_BYTES=

# Số lượt tải zip được xử lý ĐỒNG THỜI (không phải tổng số người dùng cùng lúc).
# Mặc định: 3 — mức cân bằng cho 512MB RAM / 0.1 CPU của Render free. Người tới
# sau khi đã đủ 3 lượt sẽ tự động XẾP HÀNG (không bị từ chối), xem trạng thái
# "Đang xếp hàng" ngay trên UI, không cần bấm tải lại.
MAX_CONCURRENT_DOWNLOADS=

# Basic Auth cho toàn trang — chỉ bật khi CẢ HAI biến dưới đây đều có giá trị.
# Để trống (mặc định) = ai có link cũng dùng được, không cần đăng nhập.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
